# AWS Bedrock runtime region
AWS_REGION=ap-southeast-2

# Optional: override model ID used by server/src/ai/provider.ts
# BEDROCK_MODEL_ID=apac.anthropic.claude-sonnet-4-20250514-v1:0

# ---------------------------------------------------------------------------
# Job search — Browserbase (primary, loads Seek + Indeed directly)
# Sign up: https://www.browserbase.com/
# ---------------------------------------------------------------------------
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ---------------------------------------------------------------------------
# Supplementary providers (optional, adds more sources)
# ---------------------------------------------------------------------------

# JSearch via RapidAPI — LinkedIn, Indeed, Glassdoor aggregator (free: 200 req/month)
# Sign up: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# JSEARCH_API_KEY=

# Adzuna — dedicated NZ + AU endpoints (free: 250 req/day)
# Sign up: https://developer.adzuna.com/
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
